---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string | null;
  demo?: string | null;
  featured?: boolean;
}

const { title, description, tags, github = null, demo = null, featured = false } = Astro.props;

// Color map for common tech tags
const tagColors: Record<string, string> = {
  Python: 'bg-blue-900/60 text-blue-300 border-blue-700',
  Pandas: 'bg-purple-900/60 text-purple-300 border-purple-700',
  NumPy: 'bg-cyan-900/60 text-cyan-300 border-cyan-700',
  Matplotlib: 'bg-orange-900/60 text-orange-300 border-orange-700',
  'ArcGIS Pro': 'bg-green-900/60 text-green-300 border-green-700',
  ArcPy: 'bg-green-900/60 text-green-300 border-green-700',
  GIS: 'bg-emerald-900/60 text-emerald-300 border-emerald-700',
  Hydrology: 'bg-teal-900/60 text-teal-300 border-teal-700',
  Groundwater: 'bg-teal-900/60 text-teal-300 border-teal-700',
  Watershed: 'bg-teal-900/60 text-teal-300 border-teal-700',
  Modeling: 'bg-violet-900/60 text-violet-300 border-violet-700',
  Automation: 'bg-yellow-900/60 text-yellow-300 border-yellow-700',
  Geology: 'bg-amber-900/60 text-amber-300 border-amber-700',
};

function tagClass(tag: string) {
  return tagColors[tag] ?? 'bg-slate-700/60 text-slate-300 border-slate-600';
}
---

<div
  class={`flex flex-col rounded-xl border p-6 transition-all duration-200 hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5 hover:-translate-y-0.5 ${
    featured
      ? 'bg-dark-card border-dark-border'
      : 'bg-dark-card/60 border-dark-border/60'
  }`}
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="text-white font-semibold text-lg leading-snug">{title}</h3>
    {featured && (
      <span class="shrink-0 text-xs font-mono text-accent-light border border-accent/30 rounded px-2 py-0.5 bg-accent/10">
        featured
      </span>
    )}
  </div>

  <!-- Description -->
  <p class="text-slate-400 text-sm leading-relaxed flex-1 mb-4">{description}</p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-5">
    {tags.map((tag) => (
      <span class={`text-xs font-mono px-2 py-0.5 rounded border ${tagClass(tag)}`}>
        {tag}
      </span>
    ))}
  </div>

  <!-- Links -->
  {(github || demo) && (
    <div class="flex items-center gap-3 mt-auto pt-4 border-t border-dark-border/50">
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
      )}
      {demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-accent-light hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Live Demo
        </a>
      )}
    </div>
  )}
</div>
