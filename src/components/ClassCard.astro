---
import { venmoUsername } from '../data/classes.js';

interface Props {
  id: string;
  title: string;
  subtitle: string;
  level: string;
  price: number;
  duration: string;
  format: string;
  description: string;
  topics: string[];
  stripeLink: string;
  venmoNote: string;
}

const {
  title,
  subtitle,
  level,
  price,
  duration,
  format,
  description,
  topics,
  stripeLink,
  venmoNote,
} = Astro.props;

const levelColors: Record<string, string> = {
  Beginner: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  Intermediate: 'bg-blue-50 text-blue-700 border-blue-200',
  Advanced: 'bg-purple-50 text-purple-700 border-purple-200',
};
const levelClass = levelColors[level] ?? 'bg-slate-50 text-slate-700 border-slate-200';

const encodedNote = encodeURIComponent(venmoNote);
const venmoLink = `https://venmo.com/${venmoUsername}?txn=pay&note=${encodedNote}&amount=${price}`;
const isPlaceholder = stripeLink.startsWith('YOUR_') || venmoUsername === 'YOUR_VENMO_USERNAME';
---

<div class="bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 md:p-8">
  <!-- Header row -->
  <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full border ${levelClass}`}>
          {level}
        </span>
        <span class="text-slate-400 text-sm">{duration} · {format}</span>
      </div>
      <h3 class="font-serif text-2xl font-bold text-navy">{title}</h3>
      <p class="text-slate-500 text-sm mt-0.5">{subtitle}</p>
    </div>
    <div class="text-right shrink-0">
      <span class="text-3xl font-bold text-navy">${price}</span>
      <span class="text-slate-400 text-sm">/session</span>
    </div>
  </div>

  <!-- Description -->
  <p class="text-slate-600 leading-relaxed mb-5">{description}</p>

  <!-- Topics -->
  <div class="mb-6">
    <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Topics covered</h4>
    <ul class="space-y-1.5">
      {topics.map((topic) => (
        <li class="flex items-start gap-2 text-sm text-slate-600">
          <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {topic}
        </li>
      ))}
    </ul>
  </div>

  <!-- Book CTA -->
  <a
    href="/book"
    class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-accent-dark text-white rounded-lg text-sm font-semibold transition-colors shadow-sm"
  >
    Book a Session →
  </a>
</div>
