---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Students Around the World"
  description="Countries Bojan Milinic has had the privilege of teaching students from"
  darkMode={true}
  navVariant="teaching"
>
  <meta http-equiv="refresh" content="0; url=/globe-v2/" />
  <main class="max-w-3xl mx-auto px-6 py-20">
    <p class="font-mono text-accent-light text-sm mb-3">// globe</p>
    <h1 class="font-serif text-4xl font-bold text-white mb-4">Students Around the World</h1>
    <p class="text-slate-400 mb-6">
      The globe comparison has moved to the real country-outline versions.
    </p>
    <a href="/globe-v2/" class="text-accent-light hover:text-white transition-colors">
      View the country-outline map
    </a>
  </main>
</BaseLayout>
