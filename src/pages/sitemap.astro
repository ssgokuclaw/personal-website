---
import BaseLayout from '../layouts/BaseLayout.astro';

const pages = [
  { href: '/', label: 'Home', description: 'Home / CV landing page (professional nav)' },
  { href: '/cv', label: 'CV', description: 'Full curriculum vitae — education, experience, technical background' },
  { href: '/projects', label: 'Projects', description: 'List of Python tools and data science projects' },
  { href: '/contact', label: 'Contact', description: 'Contact page for collaboration or tutoring inquiries' },
  { href: '/teaching', label: 'Teaching', description: 'Teaching overview (teaching nav)' },
  { href: '/globe', label: 'Globe', description: 'Interactive globe of countries taught in (teaching nav)' },
  { href: '/notebooks', label: 'Notebooks', description: 'Quarto notebooks for teaching (teaching nav)' },
  { href: '/book', label: 'Book', description: 'Central booking form (Formspree) — redirects to booking-confirmed' },
  { href: '/booking-confirmed', label: 'Booking Confirmed', description: 'Thank-you page shown after booking form submission' },
  { href: '/dance', label: 'Dance', description: 'Branches of Dance landing page — QR code target on flyers' },
  { href: '/dance-booking', label: 'Dance Booking', description: 'Free intro class booking page, links to /book' },
];
---

<BaseLayout title="Sitemap" darkMode={true}>
  <main class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-3xl font-bold text-white mb-2">Sitemap</h1>
    <p class="text-slate-400 text-sm mb-10">Every page on the site, for internal review. Not linked from the nav.</p>

    <ul class="divide-y divide-dark-border border-t border-b border-dark-border">
      {pages.map(({ href, label, description }) => (
        <li>
          <a href={href} class="group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-4 hover:bg-dark-card transition-colors px-2 -mx-2 rounded">
            <span class="font-mono text-xs text-accent-light shrink-0 sm:w-40">{href}</span>
            <span class="text-white font-semibold group-hover:text-accent-light transition-colors shrink-0 sm:w-36">{label}</span>
            <span class="text-slate-400 text-sm">{description}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
