---
import BaseLayout from '../layouts/BaseLayout.astro';

const cards = [
  {
    href: '/cv',
    label: 'Curriculum Vitae',
    description: 'Education, research experience, and technical background',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    accent: 'from-blue-600 to-navy',
  },
  {
    href: '/projects',
    label: 'Projects',
    description: 'Python tools and workflows built for scientific data problems',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`,
    accent: 'from-slate-600 to-slate-900',
  },
  {
    href: '/teaching',
    label: 'Teaching',
    description: '1-on-1 Python and coding tutoring sessions',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
    accent: 'from-teal-600 to-emerald-800',
  },
  {
    href: '/contact',
    label: 'Contact',
    description: 'Get in touch for collaboration or tutoring inquiries',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    accent: 'from-violet-600 to-purple-900',
  },
];
---

<BaseLayout title="Home" darkMode={true}>
  <main class="min-h-[calc(100vh-4rem-theme(spacing.16))]">
    <!-- Hero -->
    <section class="relative py-28 px-6 text-center overflow-hidden">
      <!-- Subtle grid background -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(#3b82f6 1px, transparent 1px), linear-gradient(90deg, #3b82f6 1px, transparent 1px); background-size: 40px 40px;"
      ></div>

      <div class="relative max-w-3xl mx-auto">
        <!-- Monogram -->
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-navy border-2 border-accent/30 mb-8 shadow-lg shadow-accent/10">
          <span class="font-serif text-2xl font-bold text-white">BM</span>
        </div>

        <h1 class="font-serif text-5xl md:text-6xl font-bold text-white mb-4 leading-tight">
          Bojan Milinic
        </h1>
        <p class="text-accent-light font-mono text-base mb-6 tracking-wide">
          Physical Scientist · U.S. Geological Survey
        </p>
        <p class="text-slate-400 text-lg leading-relaxed max-w-xl mx-auto mb-10">
          I study groundwater and watershed systems using Python, data science, and geospatial tools. I also teach coding to scientists and curious beginners.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/cv"
            class="px-6 py-3 bg-accent hover:bg-accent-dark text-white rounded-lg font-semibold text-sm transition-colors shadow-md"
          >
            View CV
          </a>
          <a
            href="/teaching"
            class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white border border-white/20 rounded-lg font-semibold text-sm transition-colors"
          >
            Tutoring Sessions
          </a>
        </div>
      </div>
    </section>

    <!-- Cards grid -->
    <section class="max-w-5xl mx-auto px-6 pb-20 grid grid-cols-1 sm:grid-cols-2 gap-5">
      {cards.map(({ href, label, description, icon, accent }) => (
        <a
          href={href}
          class="group relative flex items-start gap-5 p-6 rounded-xl bg-dark-card border border-dark-border hover:border-accent/40 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-accent/5"
        >
          <div class={`shrink-0 w-12 h-12 rounded-lg bg-gradient-to-br ${accent} flex items-center justify-center text-white shadow-sm`}>
            <Fragment set:html={icon} />
          </div>
          <div>
            <h2 class="text-white font-semibold text-lg mb-1 group-hover:text-accent-light transition-colors">{label}</h2>
            <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
          </div>
          <svg class="absolute right-5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-600 group-hover:text-accent/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
