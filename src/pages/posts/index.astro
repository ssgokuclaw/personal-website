---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Writing"
  description="Essays and reflections by Bojan Milinic"
  darkMode={true}
>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <section class="mb-12">
      <p class="font-mono text-accent-light text-sm mb-3">// writing</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
        Writing
      </h1>
      <p class="text-slate-400 text-lg leading-relaxed max-w-2xl">
        Essays, reflections, and notes that are now rendered by Astro from Markdown source files.
      </p>
      <div class="mt-6 flex flex-wrap gap-4 text-sm">
        <a href="/lab" class="text-accent-light hover:text-white transition-colors">Lab notes</a>
        <a href="/blog-archive" class="text-slate-400 hover:text-white transition-colors">Experiment archive</a>
      </div>
    </section>

    <section class="space-y-5">
      {posts.map((post) => (
        <article class="border border-dark-border bg-dark-card rounded-lg p-6">
          <div class="flex flex-wrap items-center gap-3 mb-3 font-mono text-xs text-slate-500">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            {post.data.category && <span>{post.data.category}</span>}
          </div>
          <h2 class="font-serif text-2xl font-semibold text-white mb-3">
            <a href={`/posts/${post.slug}`} class="hover:text-accent-light transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-slate-400 leading-relaxed mb-4">{post.data.summary}</p>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-mono text-slate-400 bg-slate-900/60 border border-dark-border rounded px-2 py-1">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
