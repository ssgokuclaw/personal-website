---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects.js';

const featured = projects.filter((p) => p.featured);
const other = projects.filter((p) => !p.featured);
---

<BaseLayout
  title="Projects"
  description="Python tools and scientific workflows built by Bojan Milinic"
  darkMode={true}
>
  <main class="max-w-6xl mx-auto px-6 py-16">

    <!-- Hero -->
    <section class="mb-16">
      <p class="font-mono text-accent-light text-sm mb-3 tracking-wide">// projects</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
        Scientific Tools &<br />Data Workflows
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl leading-relaxed">
        Python-based tools built for real hydrology and geoscience problems — automating data pipelines, geospatial workflows, and model calibration at the USGS. Most work lives in internal USGS repositories; descriptions here capture what each tool does.
      </p>

      <!-- Terminal-style stat bar -->
      <div class="mt-8 flex flex-wrap gap-6 font-mono text-sm">
        <span class="text-slate-500">
          <span class="text-accent-light">{projects.length}</span> projects
        </span>
        <span class="text-slate-500">
          <span class="text-accent-light">{[...new Set(projects.flatMap((p) => p.tags))].length}</span> technologies
        </span>
        <span class="text-slate-500">
          primary lang: <span class="text-accent-light">Python</span>
        </span>
      </div>
    </section>

    <!-- Featured projects -->
    <section class="mb-14">
      <h2 class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-6">
        ── Featured
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {featured.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            github={project.github}
            demo={project.demo}
            featured={true}
          />
        ))}
      </div>
    </section>

    <!-- Other projects -->
    {other.length > 0 && (
      <section>
        <h2 class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-6">
          ── Other Work
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {other.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              tags={project.tags}
              github={project.github}
              demo={project.demo}
              featured={false}
            />
          ))}
        </div>
      </section>
    )}

  </main>
</BaseLayout>
