---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cv } from '../data/cv.js';

// ── Replace this with your Formspree form ID ──────────────────────────
// 1. Go to https://formspree.io and create a free account
// 2. Create a new form — it will give you a form ID like "xpwzabcd"
// 3. Replace YOUR_FORMSPREE_ID below with that ID
const formspreeId = 'YOUR_FORMSPREE_ID';
const formAction = `https://formspree.io/f/${formspreeId}`;
const isPlaceholder = formspreeId === 'YOUR_FORMSPREE_ID';
// ─────────────────────────────────────────────────────────────────────
---

<BaseLayout
  title="Contact"
  description="Get in touch with Bojan Milinic"
>
  <main class="max-w-5xl mx-auto px-6 py-16">

    <!-- Header -->
    <div class="mb-12">
      <h1 class="font-serif text-4xl font-bold text-navy mb-3">Get in Touch</h1>
      <p class="text-slate-500 text-lg max-w-xl leading-relaxed">
        Whether you have a question about tutoring, want to discuss research, or just want to connect — feel free to reach out.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Contact info (left) -->
      <aside class="lg:col-span-2 space-y-6">

        <div>
          <h2 class="font-serif text-xl font-semibold text-navy mb-4">Direct contact</h2>
          <div class="space-y-4">
            <a
              href={`mailto:${cv.personal.email}`}
              class="flex items-center gap-3 text-slate-600 hover:text-accent group transition-colors"
            >
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-400 font-medium">Email</p>
                <p class="text-sm font-medium">{cv.personal.email}</p>
              </div>
            </a>

            <a
              href={`https://github.com/${cv.personal.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-slate-600 hover:text-accent group transition-colors"
            >
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-400 font-medium">GitHub</p>
                <p class="text-sm font-medium">{cv.personal.github}</p>
              </div>
            </a>

            <a
              href={`https://orcid.org/${cv.personal.orcid}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-slate-600 hover:text-accent group transition-colors"
            >
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-400 font-medium">ORCID</p>
                <p class="text-sm font-mono">{cv.personal.orcid}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="bg-navy/5 border border-navy/10 rounded-xl p-5">
          <h3 class="font-semibold text-navy text-sm mb-2">Interested in tutoring?</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Browse the <a href="/teaching" class="text-accent hover:underline">Teaching page</a> first — pick a session type that fits your level, then use this form or email directly to schedule.
          </p>
        </div>

      </aside>

      <!-- Form (right) -->
      <div class="lg:col-span-3">
        {isPlaceholder ? (
          <div class="rounded-xl bg-amber-50 border border-amber-200 p-6 text-amber-700 text-sm">
            <p class="font-semibold mb-2">Form not yet configured</p>
            <p>Set up a free account at <a href="https://formspree.io" target="_blank" rel="noopener noreferrer" class="underline">formspree.io</a>, create a form, and replace <code class="font-mono bg-amber-100 px-1 rounded">YOUR_FORMSPREE_ID</code> in <code class="font-mono bg-amber-100 px-1 rounded">src/pages/contact.astro</code>.</p>
          </div>
        ) : (
          <form
            action={formAction}
            method="POST"
            class="space-y-5"
          >
            <!-- Honeypot spam protection -->
            <input type="text" name="_gotcha" class="hidden" aria-hidden="true" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-slate-700 mb-1.5">Subject</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent bg-white transition-colors"
              >
                <option value="">Select a topic...</option>
                <option value="Tutoring inquiry">Tutoring inquiry</option>
                <option value="Research collaboration">Research collaboration</option>
                <option value="General question">General question</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows={6}
                placeholder="Tell me what you're looking for..."
                class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto px-8 py-3 bg-navy hover:bg-navy-light text-white rounded-lg font-semibold text-sm transition-colors shadow-sm"
            >
              Send Message
            </button>

            <p class="text-xs text-slate-400">
              This form is powered by <a href="https://formspree.io" target="_blank" rel="noopener noreferrer" class="underline">Formspree</a>. Your message is sent directly to my email — no data is stored by this site.
            </p>
          </form>
        )}
      </div>

    </div>
  </main>
</BaseLayout>
