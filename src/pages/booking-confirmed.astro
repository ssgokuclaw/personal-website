---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Booking Confirmed"
  description="Payment confirmed — now pick your session time"
  darkMode={true}
  navVariant="teaching"
>
  <main class="min-h-screen bg-dark-base">

    <!-- Confirmation header -->
    <section class="bg-navy py-14 px-6 text-white border-b border-navy-light">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Checkmark icon -->
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent/20 border border-accent/40 mb-6">
          <svg class="w-7 h-7 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <p class="font-mono text-accent-light text-sm tracking-widest uppercase mb-3">
          Request received
        </p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4 leading-tight">
          You're all set
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed max-w-xl mx-auto">
          Bojan will follow up within 24 hours to confirm a time. Keep an eye on your inbox.
        </p>
      </div>
    </section>

    <!-- Next steps -->
    <section class="px-6 py-14 text-center">
      <div class="max-w-md mx-auto space-y-6">
        <p class="text-slate-400 text-sm leading-relaxed">
          In the meantime, feel free to browse the session options or get in touch directly.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/teaching"
            class="px-6 py-2.5 bg-accent hover:bg-accent-dark text-white rounded-lg text-sm font-semibold transition-colors"
          >
            Browse Sessions
          </a>
          <a
            href="mailto:bojan.milinic@usgs.gov"
            class="px-6 py-2.5 bg-dark-card hover:bg-dark-border text-slate-300 border border-dark-border rounded-lg text-sm font-semibold transition-colors"
          >
            Email Bojan
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
