---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Booking Confirmed"
  description="Payment confirmed — now pick your session time"
  darkMode={true}
  navVariant="teaching"
>
  <main class="min-h-screen bg-dark-base">

    <!-- Confirmation header -->
    <section class="bg-navy py-14 px-6 text-white border-b border-navy-light">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Checkmark icon -->
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent/20 border border-accent/40 mb-6">
          <svg class="w-7 h-7 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <p class="font-mono text-accent-light text-sm tracking-widest uppercase mb-3">
          Payment confirmed
        </p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4 leading-tight">
          Now pick your session time
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed max-w-xl mx-auto">
          Your payment went through. Use the calendar below to choose a time that works for you — I'll send a video call link before we meet.
        </p>
      </div>
    </section>

    <!-- Calendly embed -->
    <section class="px-4 py-12">
      <div class="max-w-3xl mx-auto">
        <p class="text-slate-400 text-sm text-center font-mono mb-8 tracking-wide">
          Select a date and time below
        </p>

        <!-- REPLACE: your Calendly link here -->
        <div
          class="calendly-inline-widget rounded-xl overflow-hidden border border-dark-border shadow-lg"
          data-url="https://calendly.com/YOUR_CALENDLY_LINK?background_color=0f172a&text_color=cbd5e1&primary_color=3b82f6"
          style="min-width:320px;height:700px;"
        ></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      </div>
    </section>

    <!-- Footer note -->
    <section class="px-6 pb-16 text-center">
      <p class="text-slate-500 text-sm">
        Questions? Reach out at
        <a href="mailto:bojan.milinic@usgs.gov" class="text-accent-light hover:underline">
          bojan.milinic@usgs.gov
        </a>
      </p>
    </section>

  </main>
</BaseLayout>
