---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cv } from '../data/cv.js';
---

<BaseLayout title="CV" description="Curriculum vitae of Bojan Milinic — Physical Scientist at USGS">
  <main class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col lg:flex-row gap-0 shadow-md rounded-xl overflow-hidden border border-slate-200">

      <!-- ── Sidebar ── -->
      <aside class="w-full lg:w-72 xl:w-80 shrink-0 bg-slate-50 border-b lg:border-b-0 lg:border-r border-slate-200 p-8">

        <!-- Monogram / Avatar -->
        <div class="flex justify-center mb-6">
          <div class="w-24 h-24 rounded-full bg-navy flex items-center justify-center shadow-md">
            <span class="font-serif text-3xl font-bold text-white">BM</span>
          </div>
        </div>

        <!-- Name & title -->
        <div class="text-center mb-6">
          <h1 class="font-serif text-2xl font-bold text-navy leading-tight">{cv.personal.name}</h1>
          <p class="text-slate-500 text-sm mt-1">{cv.personal.title}</p>
          <p class="text-slate-400 text-xs mt-0.5">{cv.personal.organization}</p>
        </div>

        <hr class="border-slate-200 mb-6" />

        <!-- Contact -->
        <div class="mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Contact</h2>
          <ul class="space-y-2.5 text-sm text-slate-600">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-navy/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${cv.personal.email}`} class="hover:text-accent transition-colors break-all">{cv.personal.email}</a>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-navy/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{cv.personal.location}</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-navy/70" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
              <a href={`https://github.com/${cv.personal.github}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{cv.personal.github}</a>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-navy/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 015.656 0l4 4" />
              </svg>
              <a href={`https://orcid.org/${cv.personal.orcid}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors font-mono text-xs">{cv.personal.orcid}</a>
            </li>
          </ul>
        </div>

        <hr class="border-slate-200 mb-6" />

        <!-- Skills -->
        <div class="mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Skills</h2>
          {Object.entries(cv.skills).map(([category, items]) => (
            <div class="mb-4">
              <h3 class="text-xs font-semibold text-slate-500 mb-1.5">{category}</h3>
              <div class="flex flex-wrap gap-1.5">
                {(items as string[]).map((skill) => (
                  <span class="text-xs bg-navy/10 text-navy px-2 py-0.5 rounded-full border border-navy/20">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <hr class="border-slate-200 mb-6" />

        <!-- Education (sidebar summary) -->
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Education</h2>
          <ul class="space-y-3 text-sm">
            {cv.education.map((edu) => (
              <li>
                <p class="font-medium text-slate-700 leading-snug">{edu.degree}</p>
                <p class="text-slate-500 text-xs">{edu.institution}, {edu.year}</p>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- ── Main content ── -->
      <div class="flex-1 bg-white p-8 lg:p-10">

        <!-- Print button -->
        <div class="flex justify-end mb-6 print:hidden">
          <button
            onclick="window.print()"
            class="flex items-center gap-2 text-sm text-slate-500 hover:text-navy border border-slate-200 hover:border-navy/30 px-3 py-1.5 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            Print / Save PDF
          </button>
        </div>

        <!-- Career Profile -->
        <section class="mb-10">
          <h2 class="font-serif text-2xl font-bold text-navy mb-1">Career Profile</h2>
          <div class="h-0.5 w-12 bg-accent mb-5"></div>
          <p class="text-slate-600 leading-relaxed">{cv.summary}</p>
        </section>

        <!-- Professional Experience -->
        <section class="mb-10">
          <h2 class="font-serif text-2xl font-bold text-navy mb-1">Professional Experience</h2>
          <div class="h-0.5 w-12 bg-accent mb-6"></div>
          <div class="space-y-8">
            {cv.experience.map((exp) => (
              <div class="relative pl-6 border-l-2 border-slate-200">
                <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-accent"></div>
                <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                  <div>
                    <h3 class="font-semibold text-slate-800 text-base">{exp.role}</h3>
                    <p class="text-slate-500 text-sm">{exp.org}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded">{exp.period}</span>
                    <p class="text-xs text-slate-400 mt-1">{exp.location}</p>
                  </div>
                </div>
                <ul class="space-y-1.5 mt-2">
                  {exp.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <span class="text-accent mt-1.5 shrink-0">·</span>
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>

        <!-- Education -->
        <section>
          <h2 class="font-serif text-2xl font-bold text-navy mb-1">Education</h2>
          <div class="h-0.5 w-12 bg-accent mb-6"></div>
          <div class="space-y-5">
            {cv.education.map((edu) => (
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="font-semibold text-slate-800">{edu.degree}</h3>
                  <p class="text-slate-500 text-sm">{edu.institution} · {edu.location}</p>
                </div>
                <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded shrink-0">{edu.year}</span>
              </div>
            ))}
          </div>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @media print {
    aside { width: 280px !important; }
    main { padding: 0 !important; }
    header, footer { display: none !important; }
  }
</style>
